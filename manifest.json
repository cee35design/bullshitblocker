{
  "manifest_version": 3,
  "name": "bullshit blocker",
  "version": "1.4",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}   